# Remote connection (for sync-to-remote.sh)
REMOTE_USER="lab-user"
REMOTE_HOST="rhel9.example.opentlc.com"

# Local/remote directory names (for sync-to-remote.sh)
LOCAL_SOURCE_NAME="BowlandWidgetFactoryOCPStandards"
REMOTE_SOURCE_NAME="LightspeedBYOKDemo"
REMOTE_SOURCE_TARGET="LightspeedBYOKOutput"

# OpenShift image registry (for patch-olsconfig-rag.sh, podman commands)
# OCP_REGISTRY_URL is auto-populated by expose-registry.sh
OCP_REGISTRY_URL="default-route-openshift-image-registry.apps.cluster-XXXXX.dynamic.redhatworkshops.io"
OCP_API_URL="https://api.cluster-XXXXX.dynamic.redhatworkshops.io:6443"
OC_TAR_URL="https://downloads-openshift-console.apps.cluster-XXXXX.dynamic.redhatworkshops.io/amd64/linux/oc.tar"
OLS_NAMESPACE="openshift-lightspeed"

# RAG configuration (for patch-olsconfig-rag.sh)
RAG_INDEX_ID="vector_db_index"
RAG_INDEX_PATH="/rag/vector_db"

# Podman paths on remote host
MARKDOWN_SOURCE_DIR="/home/lab-user/LightspeedBYOKDemo"
OUTPUT_DIR="/home/lab-user/LightspeedBYOKOutput"
